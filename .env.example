# ---- Flask & Server ----
PORT=5000
APP_TIMEZONE=Asia/Kolkata
START_SCHEDULER=true

# ---- Google Service Account ----
# Path to your service account JSON credentials (mount or place securely)
SERVICE_ACCOUNT_FILE=/etc/secrets/service_account.json
# Either a spreadsheet name or a spreadsheet key (prefer KEY for reliability)
GOOGLE_SHEET_NAME=HitechConcertBookings
# GOOGLE_SHEET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Twilio WhatsApp ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+1415xxxxxxx
TWILIO_CONTENT_SID_CONCERT=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Security ----
# Used to authorize /broadcast/run and /clear-sheet endpoints
CLEAR_TOKEN=change-this-to-a-long-random-string

# ---- Broadcast Defaults ----
BROADCAST_ENABLE=true
BROADCAST_EVENT_TIME="This Week"
BROADCAST_SEAT_PLACEHOLDER=-
BROADCAST_NAME_FALLBACK=Guest
THROTTLE_PER_MESSAGE_SECONDS=0.15
MAX_RECIPIENTS_PER_RUN=1000
