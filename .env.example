# ---- Twilio ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+91XXXXXXXXXX
TWILIO_CONTENT_SID_SUNDAY=HXxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CONTENT_SID_WEDNESDAY=HXyyyyyyyyyyyyyyyyyyyyy
# ---- Google Sheets ----
SERVICE_ACCOUNT_FILE=/etc/secrets/service_account.json
GOOGLE_SHEET_KEY=<your_sheet_id>
# or GOOGLE_SHEET_NAME=ConcertBookings

# ---- App ----
APP_TIMEZONE=Asia/Kolkata
START_SCHEDULER=true
BROADCAST_ENABLE=true
BROADCAST_NAME_FALLBACK=Friend
THROTTLE_PER_MESSAGE_SECONDS=0.15
MAX_RECIPIENTS_PER_RUN=2000

# ---- Computed Preference ----
PREF_WINDOW_WEEKLY_DAYS=35
PREF_THRESHOLD_WEEKLY=3
PREF_WINDOW_BIWEEKLY_DAYS=60
PREF_THRESHOLD_BIWEEKLY=1
BROADCAST_PREFERENCE_DEFAULT=Weekly

# ---- Security ----
CLEAR_TOKEN=<long-strong-token>
